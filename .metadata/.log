				System.out.println("Não consegui trazer os dados do bando de dados");
			} finally {
				DB.closeResultSet(rs);
				DB.closeStatement(st);
				DB.closeStatement(stt);
				DB.closeConnection();
			}
		} else if( txtData.getValue() != null ) {
			try {
				conn = DB.getConnection();
