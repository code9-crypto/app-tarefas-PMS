<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="421.0" prefWidth="733.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ViewController">
   <children>
      <TabPane layoutX="1.0" layoutY="2.0" prefHeight="419.0" prefWidth="733.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          <Tab text="Cadastrar tarefa">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="328.0" prefWidth="491.0">
                     <children>
                        <Button fx:id="btnSalvar" layoutX="107.0" layoutY="257.0" mnemonicParsing="false" onAction="#onBtSalvar" prefHeight="75.0" prefWidth="319.0" text="Salvar">
                           <font>
                              <Font name="Arial Bold Italic" size="30.0" />
                           </font></Button>
                        <TextField fx:id="txtTarefa" layoutX="187.0" layoutY="59.0" prefHeight="25.0" prefWidth="239.0" />
                        <TextField fx:id="txtSolicitante" layoutX="187.0" layoutY="126.0" prefHeight="25.0" prefWidth="239.0" />
                        <TextField fx:id="txtDestino" layoutX="187.0" layoutY="198.0" prefHeight="25.0" prefWidth="239.0" />
                        <Label layoutX="107.0" layoutY="63.0" text="Tarefa">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Label layoutX="107.0" layoutY="129.0" text="Solicitante">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Label layoutX="107.0" layoutY="201.0" text="Destino">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="lblMensagem" layoutX="128.0" layoutY="351.0">
                           <font>
                              <Font name="System Bold Italic" size="14.0" />
                           </font>
                        </Label>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
          <Tab text="Consultar tarefa">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="390.0" prefWidth="730.0">
                     <children>
                        <Button layoutX="202.0" layoutY="301.0" mnemonicParsing="false" onAction="#onBtConsultar" prefHeight="75.0" prefWidth="319.0" text="Consultar">
                           <font>
                              <Font name="Arial Bold Italic" size="30.0" />
                           </font>
                        </Button>
                        <Label layoutX="19.0" layoutY="14.0" text="Digite o código da tarefa">
                           <font>
                              <Font name="System Bold Italic" size="14.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtConsultaCodigo" layoutX="19.0" layoutY="34.0" prefHeight="25.0" prefWidth="169.0" />
                        <Label layoutX="491.0" layoutY="12.0" text="Digite o nome do solicitante">
                           <font>
                              <Font name="System Bold Italic" size="14.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtConsultaNome" layoutX="491.0" layoutY="32.0" prefHeight="25.0" prefWidth="186.0" />
                        <TableView fx:id="table" layoutX="19.0" layoutY="83.0" prefHeight="200.0" prefWidth="660.0">
                          <columns>
                            <TableColumn fx:id="colunaTarefa" prefWidth="75.0" text="Tarefa" />
                            <TableColumn fx:id="colunaSolicitante" prefWidth="75.0" text="Solicitante" />
                              <TableColumn fx:id="colunaDestino" prefWidth="75.0" text="Destino" />
                              <TableColumn fx:id="colunaData" prefWidth="75.0" text="Data" />
                          </columns>
                        </TableView>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
