<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="421.0" prefWidth="733.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ViewController">
   <children>
      <TabPane layoutX="1.0" layoutY="2.0" prefHeight="419.0" prefWidth="733.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          <Tab text="Cadastrar tarefa">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="328.0" prefWidth="491.0">
                     <children>
                        <Button fx:id="btnSalvar" layoutX="107.0" layoutY="290.0" mnemonicParsing="false" onAction="#onBtSalvar" prefHeight="57.0" prefWidth="319.0" text="Salvar">
