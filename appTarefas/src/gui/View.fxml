                           <font>
                              <Font name="System Bold Italic" size="14.0" />
                           </font>
                        </Label>
                        <TextField fx:id="txtTafChat" layoutX="19.0" layoutY="34.0" prefHeight="25.0" prefWidth="169.0" />
                        <TextArea fx:id="txtConversa" layoutX="21.0" layoutY="95.0" prefHeight="200.0" prefWidth="682.0" />
                        <Label layoutX="21.0" layoutY="78.0" prefHeight="17.0" prefWidth="114.0" text="Conversa" />
                     </children>
                  </AnchorPane>
               </content>
